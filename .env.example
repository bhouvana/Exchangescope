# ExchangeScope — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection string
# Local dev: postgresql://postgres:postgres@localhost:5434/exchangescope
# Render:     copied from your managed database's Internal Connection String
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/exchangescope

# Finnhub API — free at https://finnhub.io/
# Used for: market caps, news, analyst ratings, earnings, insider transactions
FINNHUB_API_KEY=your_finnhub_api_key_here

# Groq API — free at https://console.groq.com/
# Used for: company research, thesis builder, daily briefing, learning assistant
GROQ_API_KEY=your_groq_api_key_here

# Session secret — any long random string
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-secret-at-least-32-chars

# API server port (default: 8082)
PORT=8082

# Set to "production" on Render
NODE_ENV=development

# Frontend URL — used for CORS in production
# FRONTEND_URL=https://your-app.onrender.com
